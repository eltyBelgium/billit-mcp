# --- Required (apikey mode) -------------------------------------------------
# Get these from https://my.sandbox.billit.be (sandbox) or https://my.billit.be (prod)
# under My Profile.
BILLIT_API_KEY=your-billit-api-key
BILLIT_PARTY_ID=12345

# --- Optional ---------------------------------------------------------------

# Default is SANDBOX. Set to https://api.billit.be only when you're sure —
# production calls trigger real invoices.
BILLIT_BASE_URL=https://api.sandbox.billit.be

# apikey | oauth
BILLIT_AUTH_MODE=apikey

# OAuth credentials (only if BILLIT_AUTH_MODE=oauth)
# Email support@billit.eu to obtain a client_id/client_secret.
# BILLIT_OAUTH_CLIENT_ID=
# BILLIT_OAUTH_CLIENT_SECRET=
# BILLIT_OAUTH_REFRESH_TOKEN=

# HTTP client tuning
BILLIT_TIMEOUT=30
BILLIT_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO

# Transport selection (stdio | http) — overridable by --transport flag
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
