{
  "name": "billit-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the Billit e-invoicing API (TypeScript). Runs over stdio for Claude/Gemini/IDEs and deploys to Cloudflare Workers.",
  "type": "module",
  "license": "MIT",
  "author": "Elty <tyas@elty.be>",
  "homepage": "https://github.com/eltyBelgium/billit-mcp",
  "bin": {
    "billit-mcp-server": "dist/stdio.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/stdio.js",
    "dev:stdio": "tsx src/stdio.ts",
    "inspect": "npx -y @modelcontextprotocol/inspector tsx src/stdio.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "agents": ">=0.6.0 <1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
